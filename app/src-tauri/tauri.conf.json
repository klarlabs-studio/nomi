{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "targets": "all",
    "externalBin": ["bin/nomid"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "productName": "Nomi",
  "mainBinaryName": "Nomi",
  "version": "0.2.2",
  "identifier": "ai.nomi.app",
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/felixgeelhaar/nomi/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGQTNCQjIwNTUwRUFDQTYKUldTbXJBNVZJTHVqWHhKT0lWRlJDQTE2WjZsbWV5S1pMZnBvN01EMkVYMmpDYTNoL0M2VFRQWXQK"
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' http://127.0.0.1:8080 ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; script-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$DOWNLOAD/**"
        ]
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Nomi",
        "width": 1200,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "visible": true
      }
    ]
  }
}
